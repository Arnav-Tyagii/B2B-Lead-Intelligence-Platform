# ─────────────────────────────────────────────────────────────────────────────
# Backend configuration. Copy to `.env` and fill in real values.
# Config is read via pydantic-settings; NEVER commit a real .env (see .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (free M0 cluster).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=lead_intelligence

# Google Gemini. Optional: if blank, the app falls back to the deterministic
# heuristic enricher (graceful degradation, no crash).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Comma-separated list of allowed CORS origins (the Vercel frontend URL).
# Use the local dev URL while developing.
CORS_ORIGINS=http://localhost:3000

# Logging / environment
LOG_LEVEL=INFO
ENVIRONMENT=development
